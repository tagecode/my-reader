{
  "name": "my-reader",
  "productName": "摸鱼阅读器",
  "private": true,
  "version": "0.1.0",
  "description": "纯本地桌面电子书阅读器（EPUB / TXT / PDF）",
  "author": "My Reader",
  "packageManager": "pnpm@10.11.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/copy-pdfjs-assets.mjs && tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "postinstall": "node scripts/copy-pdfjs-assets.mjs && electron-rebuild -f -w better-sqlite3",
    "copy:pdfjs": "node scripts/copy-pdfjs-assets.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "pack:dir": "pnpm icons && pnpm build && electron-builder --dir",
    "pack": "pnpm run pack:dir",
    "dist": "pnpm icons && pnpm build && electron-builder",
    "dist:mac": "pnpm dist --mac",
    "dist:win": "pnpm dist --win",
    "dist:linux": "pnpm dist --linux"
  },
  "dependencies": {
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@fontsource/noto-serif-sc": "^5.2.9",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.8.0",
    "foliate-js": "^1.0.1",
    "iconv-lite": "^0.7.2",
    "jschardet": "^3.1.4",
    "jszip": "^3.10.1",
    "lucide-react": "^1.17.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/babel__core": "^7.20.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^10.0.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "to-ico": "^1.1.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7",
    "wait-on": "^9.0.10"
  }
}
