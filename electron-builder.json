{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.tagecode.myreader",
  "productName": "摸鱼阅读器",
  "copyright": "Copyright © 2026 My Reader",
  "publish": null,
  "forceCodeSigning": false,
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": ["dist/**/*", "dist-electron/**/*"],
  "icon": "build/icon.png",
  "electronDist": "node_modules/electron/dist",
  "electronDownload": {
    "mirror": "https://npmmirror.com/mirrors/electron/"
  },
  "npmRebuild": true,
  "asar": true,
  "asarUnpack": ["**/node_modules/better-sqlite3/**"],
  "mac": {
    "artifactName": "MyReader-v${version}-mac-${arch}.${ext}",
    "category": "public.app-category.productivity",
    "icon": "build/icon.icns",
    "target": ["dmg", "zip"],
    "type": "development",
    "identity": null,
    "sign": false,
    "notarize": false,
    "hardenedRuntime": false,
    "gatekeeperAssess": false,
    "extendInfo": {
      "CFBundleName": "摸鱼阅读器",
      "CFBundleDisplayName": "摸鱼阅读器"
    }
  },
  "win": {
    "artifactName": "MyReader-v${version}-win-${arch}.${ext}",
    "icon": "build/icon.ico",
    "target": ["nsis"]
  },
  "linux": {
    "artifactName": "MyReader-v${version}-linux-${arch}.${ext}",
    "icon": "build/icons",
    "target": ["AppImage", "deb"],
    "category": "Office;Viewer",
    "maintainer": "My Reader"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "uninstallDisplayName": "${productName} v${version}",
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico"
  },
  "fileAssociations": [
    {
      "ext": "epub",
      "name": "EPUB Ebook",
      "role": "Viewer"
    },
    {
      "ext": "txt",
      "name": "Text Ebook",
      "role": "Viewer"
    },
    {
      "ext": "pdf",
      "name": "PDF Document",
      "role": "Viewer"
    }
  ]
}
